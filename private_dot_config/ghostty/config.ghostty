theme = Afterglow

background-opacity = 0.85
background-blur = true

# Split right (vertical split)
keybind = ctrl+alt+r=new_split:right

# Split down (horizontal split)
keybind = ctrl+alt+d=new_split:down

keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:top
keybind = alt+down=goto_split:bottom
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+x=toggle_split_zoom

